# edgelab-odds environment variables
# Copy to .env and fill in values: cp .env.example .env

# ── Database ───────────────────────────────────────────────
# Path to the DuckDB database file (relative to project root)
DB_PATH=data/edgelab.duckdb

# ── Data ───────────────────────────────────────────────────
# Path to the raw UFC master CSV
UFC_CSV_PATH=data/ufc-master.csv

# ── Odds API (optional — for live odds feeds) ──────────────
# Obtain a free key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ── Model ──────────────────────────────────────────────────
# Directory where trained model artifacts are saved
MODEL_DIR=models

# Random seed for reproducibility
RANDOM_SEED=42

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
